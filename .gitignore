.DS_Store

# Local config may contain OIDC client secrets.
config.yml
config.yaml
examples/config.yml
examples/config.yaml

# Build/test artifacts
/bin/
dist/
/coverage/
*.test
*.out
*.tsbuildinfo

# Release builds copy web/dist here before go build so the frontend can be
# embedded into the Go binary. Keep the placeholder index tracked so Go builds
# still compile before a frontend build has run.
!internal/webui/
!internal/webui/dist/
!internal/webui/dist/index.html
internal/webui/dist/*
!internal/webui/dist/index.html

# Runtime data: users/operators must back these up manually.
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
leveldb/
data/

# Frontend dependencies, when the UI package is added.
node_modules/

# Playwright artifacts.
web/test-results/
web/playwright-report/
web/e2e/.runtime/
web/e2e/.shots/
.playwright-mcp/

# Example repository runtime artifacts.
examples/metadata/
examples/workflow/
examples/form/

local_data/
